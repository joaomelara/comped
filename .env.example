# ========================================
# Exemplo de variáveis de ambiente
# Copie este arquivo para .env.staging ou .env.prod e preencha os valores
# ========================================

SPRING_PROFILE=staging

APP_PORT=8080

# Oracle DB
ORACLE_PASSWORD=sua_senha_oracle

# Datasource
DB_URL=jdbc:oracle:thin:@oracle:1521:xe
DB_USERNAME=system
DB_PASSWORD=sua_senha_db
DB_SCHEMA=SEU_SCHEMA

# JPA / Flyway
JPA_DDL_AUTO=update
FLYWAY_BASELINE=true

# Segurança JWT
JWT_SECRET=sua_chave_jwt_secreta_longa

# Logging (DEBUG | INFO | WARN | ERROR)
LOG_LEVEL=INFO